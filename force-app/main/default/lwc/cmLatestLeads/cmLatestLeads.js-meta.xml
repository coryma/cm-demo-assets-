<?xml version="1.0" encoding="UTF-8" ?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <apiVersion>60.0</apiVersion>
  <isExposed>true</isExposed>
  <masterLabel>CM - 最新的潛在客戶（今日）</masterLabel>
  <targets>
    <target>lightning__AppPage</target>
    <target>lightning__HomePage</target>
    <target>lightning__RecordPage</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightning__AppPage,lightning__HomePage,lightning__RecordPage">
      <property name="pollingMs" type="Integer" label="輪詢頻率（毫秒）" default="10000"
                description="建議 ≥ 5000ms"/>
      <property name="limitSize" type="Integer" label="顯示筆數" default="20"
                description="每次擷取與顯示的筆數上限"/>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>